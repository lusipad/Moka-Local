# 复制此文件为 .env 并填写真实值

# Moka API 配置（三项都填即切换为真实 API，不填则使用 Mock）
MOKA_BASE_URL=https://openapi.moka.com
MOKA_API_KEY=your_client_id
MOKA_CLIENT_SECRET=your_client_secret

# OCR 引擎选择（paddleocr | tesseract | custom）
OCR_ENGINE=paddleocr

# AI 提取器选择（rule | openai | custom）
AI_EXTRACTOR=rule
# AI_API_URL=https://api.openai.com/v1
# AI_API_KEY=sk-...
# AI_MODEL=gpt-4o
